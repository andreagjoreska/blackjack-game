<?xml version="1.0" encoding="UTF-8"?>
<project name="cartes" default="run" basedir=".">

    <property name="src.dir" value="src"/>
    <property name="test.dir" value="src/carte/test"/>
    <property name="build.dir" value="build"/>
    <property name="test.build.dir" value="test-build"/>
    <property name="jar.file" value="cartes.jar"/>

    <target name="clean">
        <delete dir="${build.dir}"/>
        <delete dir="${test.build.dir}"/>
        <delete dir="doc"/>
    </target>

    <!-- MAIN COMPILE -->
    <target name="compile" depends="clean">
        <mkdir dir="${build.dir}"/>

        <javac srcdir="${src.dir}"
               destdir="${build.dir}"
               includeantruntime="false">

            <!-- EXCLUDE TEST FOLDER -->
            <exclude name="carte/test/**"/>

        </javac>
    </target>

    <!-- JAR BUILD -->
    <target name="jar" depends="compile">
        <mkdir dir="dist"/>

        <jar destfile="dist/${jar.file}" basedir="${build.dir}">
            <manifest>
                <attribute name="Main-Class" value="carte.Main"/>
            </manifest>
        </jar>

        <echo>cartes.jar created.</echo>
    </target>

    <!-- RUN -->
    <target name="run" depends="jar">
        <java fork="true" classname="carte.Main">
            <classpath>
                <pathelement path="dist/${jar.file}"/>
            </classpath>
        </java>
    </target>

    <!-- TEST -->
    <target name="test" depends="compile">

        <mkdir dir="${test.build.dir}"/>

        <javac srcdir="${test.dir}"
               destdir="${test.build.dir}"
               includeantruntime="false">

            <classpath>
                <pathelement path="${build.dir}"/>
                <pathelement path="dist/junit-4.13.2.jar"/>
                <pathelement path="dist/hamcrest-core-1.3.jar"/>
            </classpath>

        </javac>

        <java classname="org.junit.runner.JUnitCore" fork="true">
            <classpath>
                <pathelement path="${test.build.dir}"/>
                <pathelement path="${build.dir}"/>
                <pathelement path="dist/junit-4.13.2.jar"/>
                <pathelement path="dist/hamcrest-core-1.3.jar"/>
            </classpath>

            <arg value="test.model.CarteTest"/>
            <arg value="test.model.FactoryTest"/>
            <arg value="test.model.PaquetTest"/>

        </java>

    </target>

        <target name="javadoc" depends="compile">
        <mkdir dir="doc"/>

        <javadoc
            sourcepath="${src.dir}"
            destdir="doc"
            use="true"
            packagenames="carte,carte.model.*,carte.util.*,carte.util.observer.*">

            <fileset dir="${src.dir}">
                <include name="carte/**"/>
                <exclude name="carte/test/**"/>
            </fileset>

        </javadoc>

        <echo>Javadoc generated in /doc</echo>
    </target>

</project>


